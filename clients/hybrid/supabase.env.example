# Salin ke apps/premium-web/.env.local (jangan commit).
# Project: akuntansi-hybrid-lab

# --- Wajib untuk Premium web ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — jangan expose ke browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Legacy bridge GAS (TIDAK dipakai Premium Tahap D) ---
# Premium sekarang posting ke journal_entries di Supabase.
# Vars di bawah hanya untuk eksperimen / rollback bridge hybrid.
# HYBRID_GAS_WEBAPP_URL=https://script.google.com/macros/s/.../exec
# HYBRID_BACKEND_URL=https://script.google.com/macros/s/.../exec
# HYBRID_BACKEND_API_KEY=AKUNTANSI_HYBRID_...
# HYBRID_DATABASE_SHEET_ID=18QA03LzJspoZi0sDyoJLnA_5s1HEqLpfgzJfPxUnp7c

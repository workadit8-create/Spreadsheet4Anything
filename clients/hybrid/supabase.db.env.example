# Salin ke supabase.db.env (jangan commit).
# Supabase → Connect → Session pooler (port 5432 otomatis)
#
# CARA TERMUDAH — isi field terpisah (password boleh ada / @ # % tanpa encode):
SUPABASE_DB_HOST=aws-1-ap-southeast-1.pooler.supabase.com
# Port 5432 (session) kadang timeout di beberapa jaringan — pakai 6543 (transaction) untuk migration.
SUPABASE_DB_PORT=6543
SUPABASE_DB_USER=postgres.egpzdtbdctlcfogknvxz
SUPABASE_DB_PASSWORD=
SUPABASE_DB_NAME=postgres
#
# Alternatif satu baris (password harus URL-encode jika ada karakter khusus):
# DATABASE_URL=postgresql://postgres.egpzdtbdctlcfogknvxz:<password>@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres
#
# Email user di Authentication → Users (untuk auto-link membership)
LAB_USER_EMAIL=

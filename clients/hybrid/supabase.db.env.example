# Salin ke supabase.db.env (jangan commit).
# Supabase → Project Settings → Database → Connection string → URI
#
# PENTING: jangan pakai host db.<ref>.supabase.co — sering ENOTFOUND di Mac/jaringan IPv4.
# Pakai Session pooler (port 5432), bukan Transaction pooler (6543) untuk migration.
#
# Contoh (ganti <ref>, <region>, <password>):
# DATABASE_URL=postgresql://postgres.egpzdtbdctlcfogknvxz:<password>@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres
#
# Password dengan karakter khusus harus URL-encode (mis. $ → %24).
#
# Email user yang sudah dibuat di Authentication → Users (untuk auto-link membership)
LAB_USER_EMAIL=

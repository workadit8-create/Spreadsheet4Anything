# Salin ke supabase.db.env (jangan commit).
# Supabase → Project Settings → Database → Connection string → URI
# Mode: Session pooler atau Direct connection
#
# Contoh:
# DATABASE_URL=postgresql://postgres.egpzdtbdctlcfoqknvxz:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres
#
# Email user yang sudah dibuat di Authentication → Users (untuk auto-link membership)
LAB_USER_EMAIL=
